# Порт API (по умолчанию 3001)
PORT=3001

# Таймзона
TZ=Europe/Rome

# Режим работы
NODE_ENV=production

# Интервал синхронизации календарей (в минутах, по умолчанию 60)
SYNC_INTERVAL=60

# Опциональные настройки для будущих фич
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# NOTIFICATION_EMAIL=admin@atrani.it
